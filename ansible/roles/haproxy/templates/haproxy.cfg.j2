global
    log /dev/log local0
    log /dev/log local1 notice

    daemon

    stats socket /run/haproxy/admin.sock mode 660 level admin
    stats timeout 30s

defaults
    log global
    mode http

    option httplog
    option dontlognull

    timeout connect 5s
    timeout client  50s
    timeout server  50s

    retries 3

frontend http_front
    bind *:{{ haproxy_frontend_port }}

    default_backend app_backend

backend app_backend
    balance roundrobin

{% for server in backend_servers %}
    server {{ server.name }} {{ server.host }}:{{ server.port }} check
{% endfor %}

listen stats
    bind *:{{ haproxy_stats_port }}

    stats enable
    stats uri {{ haproxy_stats_uri }}

    stats realm HAProxy\ Statistics

    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}

    stats refresh 10s

frontend prometheus_metrics
    bind *:8405

    mode http

    http-request use-service prometheus-exporter if { path {{ haproxy_metrics_uri }} }

    no log
